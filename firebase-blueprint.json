{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student, staff, or admin user of the UNN BookHub.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "studentId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "faculty": { "type": "string" },
        "department": { "type": "string" },
        "level": { "type": "string" },
        "avatar": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["STUDENT", "STAFF", "ADMIN"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Book": {
      "title": "Book",
      "description": "An academic book available for purchase or borrowing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uniqueBookId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "isbn": { "type": "string" },
        "type": { "type": "string", "enum": ["TEXTBOOK", "WORKBOOK", "NOVEL", "JOURNAL", "REFERENCE"] },
        "courseCode": { "type": "string" },
        "courseName": { "type": "string" },
        "faculty": { "type": "string" },
        "department": { "type": "string" },
        "level": { "type": "string" },
        "authorId": { "type": "string" },
        "publishedYear": { "type": "number" },
        "edition": { "type": "string" },
        "coverImage": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stockCount": { "type": "number" },
        "isELibraryAvailable": { "type": "boolean" },
        "borrowPrice1Day": { "type": "number" },
        "borrowPrice3Days": { "type": "number" },
        "borrowPrice7Days": { "type": "number" },
        "borrowPrice14Days": { "type": "number" },
        "borrowPrice30Days": { "type": "number" },
        "totalPages": { "type": "number" },
        "previewPages": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string" },
        "averageRating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uniqueBookId", "title", "price"]
    },
    "Author": {
      "title": "Author",
      "description": "An author of academic books.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "photo": { "type": "string" },
        "nationality": { "type": "string" },
        "institution": { "type": "string" },
        "specialization": { "type": "string" }
      },
      "required": ["name"]
    },
    "Department": {
      "title": "Department",
      "description": "A department within a faculty at UNN.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "faculty": { "type": "string" },
        "level": { "type": "string" }
      },
      "required": ["name", "code", "faculty"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order for books.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "PAID", "FAILED", "REFUNDED"] },
        "totalAmount": { "type": "number" },
        "paymentRef": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paidAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "totalAmount", "status"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "An item within an order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "bookId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "uniqueBookId": { "type": "string" }
      },
      "required": ["orderId", "bookId", "quantity", "price"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "An official purchase receipt.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "stampHash": { "type": "string" },
        "qrCode": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "printedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["receiptNumber", "orderId", "userId"]
    },
    "BorrowRecord": {
      "title": "BorrowRecord",
      "description": "A record of a borrowed e-book.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "duration": { "type": "number" },
        "amountPaid": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "EXPIRED", "RETURNED"] },
        "accessToken": { "type": "string" }
      },
      "required": ["userId", "bookId", "duration", "status"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "A student complaint or issue report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "orderId": { "type": "string" },
        "bookId": { "type": "string" },
        "type": { "type": "string", "enum": ["WRONG_BOOK", "PAYMENT_ISSUE", "DAMAGED", "OTHER"] },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "IN_REVIEW", "RESOLVED", "CLOSED"] },
        "adminResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "subject", "description", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A book review and rating.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bookId", "rating"]
    },
    "ReadingProgress": {
      "title": "ReadingProgress",
      "description": "A user's progress in an e-book.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "currentPage": { "type": "number" },
        "lastReadAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bookId", "currentPage"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/books/{bookId}": { "schema": "Book", "description": "Book catalog" },
    "/authors/{authorId}": { "schema": "Author", "description": "Author directory" },
    "/departments/{deptId}": { "schema": "Department", "description": "University departments" },
    "/orders/{orderId}": { "schema": "Order", "description": "Purchase orders" },
    "/orderItems/{itemId}": { "schema": "OrderItem", "description": "Items in orders" },
    "/receipts/{receiptId}": { "schema": "Receipt", "description": "Official receipts" },
    "/borrowRecords/{recordId}": { "schema": "BorrowRecord", "description": "E-library borrowings" },
    "/complaints/{complaintId}": { "schema": "Complaint", "description": "Student complaints" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Book reviews" },
    "/readingProgress/{progressId}": { "schema": "ReadingProgress", "description": "E-book reading progress" }
  }
}
